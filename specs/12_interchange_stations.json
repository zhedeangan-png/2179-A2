{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Central stations connect the most lines",
    "subtitle": "Each dot shows a line available at an interchange station."
  },
  "width": 460,
  "height": 390,
  "padding": {
    "left": 5,
    "right": 5,
    "top": 5,
    "bottom": 5
  },
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "layer": [
    {
      "data": {
        "url": "data/interchange_stations.csv"
      },
      "transform": [
        {
          "filter": "datum.route_count >= 2 && indexof(datum.lines, 'AGL') >= 0"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 85,
        "filled": true,
        "color": "#E69F00",
        "stroke": "white",
        "strokeWidth": 0.8
      },
      "encoding": {
        "x": {
          "datum": "LRT Ampang",
          "type": "nominal",
          "title": null,
          "scale": {
            "domain": [
              "LRT Ampang",
              "LRT Sri Petaling",
              "LRT Kelana Jaya",
              "MRT Kajang",
              "MRT Putrajaya",
              "KL Monorail",
              "BRT Sunway"
            ]
          },
          "axis": {
            "labelAngle": -35,
            "labelLimit": 90
          }
        },
        "y": {
          "field": "station_name",
          "type": "nominal",
          "sort": {
            "field": "route_count",
            "op": "max",
            "order": "descending"
          },
          "title": null,
          "axis": {
            "labelLimit": 105
          }
        },
        "tooltip": [
          {
            "field": "station_name",
            "type": "nominal",
            "title": "Station"
          },
          {
            "datum": "LRT Ampang Line",
            "type": "nominal",
            "title": "Connected line"
          },
          {
            "field": "route_count",
            "type": "quantitative",
            "title": "Connected lines"
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/interchange_stations.csv"
