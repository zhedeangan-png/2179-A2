{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Average waiting time by line",
    "subtitle": "Lower headway usually means shorter waits."
  },
  "width": 430,
  "height": 300,
  "padding": {
    "left": 10,
    "right": 20,
    "top": 10,
    "bottom": 35
  },
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "data": {
    "url": "data/frequency_summary_by_line.csv"
  },
  "transform": [
    {
      "filter": "datum.service_id == 'MonFri'"
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4
  },
  "encoding": {
    "x": {
      "field": "avg_headway_min",
      "type": "quantitative",
      "title": "Average headway, minutes",
      "axis": {
        "grid": true,
        "tickCount": 5
      }
    },
    "y": {
      "field": "route_long_name",
      "type": "nominal",
      "sort": "x",
      "title": null,
      "axis": {
        "labelLimit": 160
      }
    },
    "color": {
      "condition": [
        {
          "test": "datum.avg_headway_min <= 5",
          "value": "#0072B2"
        }
      ],
      "value": "#CBD5E1"
    },
    "tooltip": [
      {
        "field": "route_long_name",
        "type": "nominal",
        "title": "Line"
      },
      {
        "field": "avg_headway_min",
        "type": "quantitative",
        "title": "Avg headway (min)",
        "format": ".1f"
      },
      {
        "field": "min_headway_min",
        "type": "quantitative",
        "title": "Min headway (min)",
        "format": ".1f"
      },
      {
        "field": "max_headway_min",
        "type": "quantitative",
        "title": "Max headway (min)",
        "format": ".1f"
      }
    ]
  },
  "config": {
    "font": "Inter, Arial, sans-serif",
    "title": {
      "font": "Inter, Arial, sans-serif",
      "fontSize": 18,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#1f2937",
      "subtitleFont": "Inter, Arial, sans-serif",
      "subtitleFontSize": 12,
      "subtitleColor": "#64748b"
    },
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#374151",
      "titleColor": "#374151",
      "gridColor": "#e5e7eb",
      "domainColor": "#94a3b8",
      "tickColor": "#94a3b8"
    },
    "view": {
      "stroke": null
    },
    "background": "#ffffff"
  }
}
