{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Average daily ridership in April 2026",
    "subtitle": "MRT Kajang and LRT Kelana Jaya carry the highest daily ridership."
  },
  "width": 460,
  "height": 385,
  "padding": {
    "left": 5,
    "right": 45,
    "top": 5,
    "bottom": 5
  },
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "data": {
    "url": "data/latest_common_month_summary.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4
      },
      "encoding": {
        "x": {
          "field": "avg_daily_ridership",
          "type": "quantitative",
          "axis": {
            "title": null,
            "grid": true,
            "format": "~s",
            "tickCount": 5
          }
        },
        "y": {
          "field": "line",
          "type": "nominal",
          "sort": [
            "MRT Kajang",
            "LRT Kelana Jaya",
            "LRT Ampang/Sri Petaling",
            "MRT Putrajaya",
            "KL Monorail",
            "BRT Sunway"
          ],
          "title": null,
          "axis": {
            "labelLimit": 150
          }
        },
        "color": {
          "condition": [
            {
              "test": "datum.line === 'MRT Kajang'",
              "value": "#8C564B"
            },
            {
              "test": "datum.line === 'LRT Kelana Jaya'",
              "value": "#0072B2"
            }
          ],
          "value": "#CBD5E1"
        },
        "tooltip": [
          {
            "field": "line",
            "type": "nominal",
            "title": "Line"
          },
          {
            "field": "avg_daily_ridership",
            "type": "quantitative",
            "title": "Avg daily riders",
            "format": ","
          },
          {
            "field": "days_observed",
            "type": "quantitative",
            "title": "Days observed"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 5,
        "fontSize": 11,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {
          "field": "avg_daily_ridership",
          "type": "quantitative"
        },
        "y": {
          "field": "line",
          "type": "nominal",
          "sort": [
            "MRT Kajang",
            "LRT Kelana Jaya",
            "LRT Ampang/Sri Petaling",
            "MRT Putrajaya",
            "KL Monorail",
            "BRT Sunway"
          ]
        },
        "text": {
          "field": "avg_daily_ridership",
          "type": "quantitative",
          "format": "~s"
        },
        "color": {
          "condition": [
            {
              "test": "datum.line === 'MRT Kajang' || datum.line === 'LRT Kelana Jaya'",
              "value": "#1f2937"
            }
          ],
          "value": "#64748b"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "line": "MRT Kajang",
            "avg_daily_ridership": 270686,
            "note": "Highest average ridership"
          },
          {
            "line": "LRT Kelana Jaya",
            "avg_daily_ridership": 259802,
            "note": "Close second"
          }
        ]
      },
      "transform": [
        {
          "calculate": "datum.avg_daily_ridership / 2",
          "as": "midpoint"
        }
      ],
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#ffffff"
      },
      "encoding": {
        "x": {
          "field": "midpoint",
          "type": "quantitative"
        },
        "y": {
          "field": "line",
          "type": "nominal",
          "sort": [
            "MRT Kajang",
            "LRT Kelana Jaya",
            "LRT Ampang/Sri Petaling",
            "MRT Putrajaya",
            "KL Monorail",
            "BRT Sunway"
          ]
        },
        "text": {
          "field": "note"
        }
      }
    }
  ],
  "config": {
    "font": "Inter, Arial, sans-serif",
    "title": {
      "font": "Georgia, 'Times New Roman', serif",
      "fontSize": 18,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#1f2937",
      "subtitleFont": "Inter, Arial, sans-serif",
      "subtitleFontSize": 12,
      "subtitleColor": "#64748b"
    },
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#334155",
      "gridColor": "#e5e7eb",
      "domainColor": "#94a3b8",
      "tickColor": "#94a3b8"
    },
    "view": {
      "stroke": null
    },
    "background": "#ffffff"
  }
}
